# Klaviyo waitlist — https://www.klaviyo.com/settings/account/api-keys
# Public key (Site ID) + List ID are enough for the landing page form.

NEXT_PUBLIC_KLAVIYO_PUBLIC_API_KEY=YOUR_PUBLIC_SITE_ID
NEXT_PUBLIC_KLAVIYO_LIST_ID=YOUR_LIST_ID

# Optional server-side fallback (private key — never expose in the browser)
KLAVIYO_PRIVATE_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KLAVIYO_LIST_ID=YOUR_LIST_ID
